              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/StatsReturnModel"
                }
              }
            }
          }
        }
      }
    },
    "/workers/{walletid}/{workerid}/{range}": {
      "get": {
        "tags": [
          "workers"
        ],
        "summary": "Get Worker Stats by Range",
        "description": "Returns hashrate data for a specific worker within a given time range. Available for apiVersion:200 coins (ETC, KAS, RVN, ZEC, ETHW, etc.).",
        "operationId": "getWorkerRange",
        "parameters": [
          {
            "name": "walletid",
            "in": "path",
            "description": "id of the wallet",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workerid",
            "in": "path",
            "description": "id of the worker",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "range",
            "in": "path",
            "description": "time range for data",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "5m",
                "30m",
                "6h"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns worker hashrate data for the specified range",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WorkerRangeReturnModel"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/WorkerRangeReturnModel"
                }
              }
            }
          }
        }
      }
    },
    "/accounts/{walletid}/shares/{range}": {
      "get": {
        "tags": [
          "accounts"
        ],
        "summary": "Get Account Shares by Range",
        "description": "Returns share statistics for an account within a given time range. Available for apiVersion:200 coins (ETC, KAS, RVN, ZEC, ETHW, etc.).",
        "operationId": "getAccountSharesRange",
        "parameters": [
          {
            "name": "walletid",
            "in": "path",
            "description": "id of the wallet",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "range",
            "in": "path",
            "description": "time range for data",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "5m",
                "30m",
                "6h"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns share data for the specified range",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SharesRangeReturnModel"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/SharesRangeReturnModel"
                }
              }
            }
          }
        }
      }
    }
