  "paths": {
    "/accounts/{walletid}": {
      "get": {
        "tags": [
          "accounts"
        ],
        "summary": "View an Account",
        "description": "",
        "operationId": "getStats",
        "parameters": [
          {
            "name": "walletid",
            "in": "path",
            "description": "id of the wallet",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns the account info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccountReturnModel"
                }
              },
              "application/xml": {
                "schema": {
                  "$ref": "#/components/schemas/AccountReturnModel"
                }
              }
            }
          }
        }
      }
    },
    "/blocks": {
      "get": {
        "tags": [
          "blocks"
        ],
        "summary": "Get all Blocks",
        "description": "",
        "operationId": "getStats",
        "responses": {
          "200": {
            "description": "Returns a list of all Block",
            "content": {
